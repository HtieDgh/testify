        <mxCell id="HcKqTVsdb6viHk0sIlYB-40" value="Дескриптор ответа содержит строку веденую пользователем в случае открытого вопроса или NULL, в случае закрытого" style="shape=note2;boundedLbl=1;whiteSpace=wrap;html=1;size=25;verticalAlign=top;align=center;fontSize=9;" parent="1" vertex="1">
          <mxGeometry x="85" y="140" width="120" height="110" as="geometry" />
        </mxCell>
        <mxCell id="HcKqTVsdb6viHk0sIlYB-41" value="" style="endArrow=none;dashed=1;html=1;rounded=0;" parent="1" source="HcKqTVsdb6viHk0sIlYB-40" target="HcKqTVsdb6viHk0sIlYB-37" edge="1">
