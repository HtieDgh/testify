            <mxPoint x="550" y="270" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="HcKqTVsdb6viHk0sIlYB-42" value="&lt;div style=&quot;font-size: 9px;&quot;&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;Цена и Штраф - целое число (может быть отрицательным) на которое увеличится сумма баллов в результате (sum) Участника тестирования, при этом:&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 9px;&quot;&gt;sum += Цена если (Дескриптор = Текст ИЛИ Вопрос закрытый)&lt;/div&gt;&lt;div style=&quot;font-size: 9px;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 9px;&quot;&gt;sum+= Штраф если (Дескриптор != Текст И вопрос открытый)&lt;/div&gt;&lt;div style=&quot;font-size: 9px;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 9px;&quot;&gt;У закрытого вопроса Штраф у его Ответов по умолчанию равен 0 и составителю теста достаточно вписать отрицательную сумму если он хочет &quot;наказать&quot; за выбор такого варианта&lt;/div&gt;" style="shape=note2;boundedLbl=1;whiteSpace=wrap;html=1;size=25;verticalAlign=top;align=center;fontSize=9;" parent="1" vertex="1">
          <mxGeometry x="70" y="300" width="150" height="220" as="geometry" />
        </mxCell>
        <mxCell id="HcKqTVsdb6viHk0sIlYB-43" value="" style="endArrow=none;dashed=1;html=1;rounded=0;" parent="1" source="HcKqTVsdb6viHk0sIlYB-42" target="HcKqTVsdb6viHk0sIlYB-31" edge="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="210" y="350.55" as="sourcePoint" />
            <mxPoint x="240" y="359.55" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="HcKqTVsdb6viHk0sIlYB-45" value="" style="endArrow=none;dashed=1;html=1;rounded=0;" parent="1" source="HcKqTVsdb6viHk0sIlYB-46" target="HcKqTVsdb6viHk0sIlYB-20" edge="1">
