          </mxGeometry>
        </mxCell>
        <mxCell id="wM_eBRZhTEVxnyZsEIDz-64" value="&lt;div style=&quot;font-size: 9px;&quot;&gt;Ссылка - уникальная последовательность для прохождения конкретного теста&lt;/div&gt;" style="shape=note2;boundedLbl=1;whiteSpace=wrap;html=1;size=25;verticalAlign=top;align=center;fontSize=9;" parent="1" vertex="1">
